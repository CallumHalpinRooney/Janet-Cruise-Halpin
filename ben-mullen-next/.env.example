# Resend — powers the enquiry form (/api/contact).
# Create a key at https://resend.com/api-keys, then copy this file to
# `.env.local` and paste the key below.
RESEND_API_KEY=

# Where enquiries are delivered. Defaults to the practice office address.
CONTACT_TO_EMAIL=office@benmullen.ie

# The verified sender the form posts as. Until a domain is verified in
# Resend, "onboarding@resend.dev" works for testing.
CONTACT_FROM_EMAIL=enquiries@benmullen.ie
